apiVersion: apps/v1
kind: DaemonSet
metadata:
  name: gke-elasticsearch-max-map-count-setter
  namespace: {{ dsc.sonarqube.namespace }}
  labels:
    app.kubernetes.io/name: gke-elasticsearch-max-map-count-setter
spec:
  selector:
    matchLabels:
      app.kubernetes.io/instance: gke-elasticsearch-max-map-count-setter
  template:
    metadata:
      labels:
        app.kubernetes.io/name: gke-elasticsearch-max-map-count-setter
        app.kubernetes.io/instance: gke-elasticsearch-max-map-count-setter
    spec:
      # nodeSelector:
      #   cloud.google.com/compute-class: "Balanced"
      initContainers:
        - name: gke-elasticsearch-max-map-count-setter
          image: docker.io/bash:5.2
          securityContext:
            privileged: true
            runAsUser: 0
          command: ['/usr/local/bin/bash', '-e', '-c', 'echo 262144 > /proc/sys/vm/max_map_count']
          resources:
            requests:
              cpu: 10m
              memory: 16Mi
            limits:
              cpu: 10m
              memory: 16Mi
      containers:
        - name: sleep
          image: docker.io/bash:5.2
          command: ['sleep', 'infinity']
          resources:
            requests:
              cpu: 10m
              memory: 16Mi
            limits:
              cpu: 10m
              memory: 16Mi